#!/usr/bin/env bash

set -euo pipefail

source "$(dirname "$0")/lib/github-cli-common.sh"

if ! gh_bin="$(find_gh_binary)"; then
  workshopctl set-health --code=missing-gh error "gh-cli binary missing"
  exit 1
fi

if ! output=$(sudo -u workshop --login "$gh_bin" --version 2>&1); then
  printf '%s\n' "$output" >&2
  workshopctl set-health --code=gh-version-failed error "gh --version failed; inspect workshop changes"
  exit 1
fi

workshopctl set-health okay